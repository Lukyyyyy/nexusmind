# Copy this file to .env.local and fill in real keys when needed.

BACKEND_PORT=18081

ADMIN_USERNAME=admin
ADMIN_PASSWORD=nexusmind123

MYSQL_ROOT_PASSWORD=nexusmind-local
MYSQL_PASSWORD=nexusmind-local
MYSQL_HOST_PORT=13306
MYSQL_PORT=13306

REDIS_PASSWORD=nexusmind-local
REDIS_HOST_PORT=6379
REDIS_PORT=6379

ELASTICSEARCH_PASSWORD=nexusmind-local
ELASTICSEARCH_HOST_PORT=9200
ELASTICSEARCH_PORT=9200

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=nexusmind-local
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=nexusmind-local
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MINIO_API_PORT=19000

KAFKA_HOST_PORT=9092
KAFKA_CONTROLLER_HOST_PORT=9093
KAFKA_PORT=9092

JWT_SECRET_KEY=nexusmind-local-development-secret-key-change-before-production

DEEPSEEK_API_KEY=
EMBEDDING_API_KEY=

MINERU_BASE_URL=http://localhost:18000
MINERU_PARSE_PATH=/file_parse
MINERU_PARSE_METHOD=auto
MINERU_OCR=false
MINERU_ENABLE_TABLE=false
MINERU_ENABLE_FORMULA=false
MINERU_API_HOST_PORT=18000
MINERU_MODEL_SOURCE=local
MINERU_MODEL_DOWNLOAD_SOURCE=huggingface
MINERU_MODEL_DOWNLOAD_TYPE=pipeline
MINERU_SKIP_MODEL_DOWNLOAD=false
# Only used with backend/docs/docker-compose.mineru-gpu.yaml.
MINERU_GPU_DEVICE_IDS=0
# If model download fails inside the MinerU container, use host.docker.internal instead of 127.0.0.1.
# Example: MINERU_HTTP_PROXY=http://host.docker.internal:7890
MINERU_HTTP_PROXY=
MINERU_HTTPS_PROXY=
MINERU_NO_PROXY=localhost,127.0.0.1

LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
